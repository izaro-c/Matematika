classDiagram
    %% Core State (Zustand Global)
    class ContentStore {
        -Record~string, ContentEntry~ index
        -Map~string, Demo~ demos
        -Record~string, Tree~ taxonomy
        +getTheorem(id: string) Theorem
        +getLesson(id: string) Lesson
        +getExamplesByTheorem(id: string) Example[]
        +getExercisesByTheorem(id: string) Exercise[]
        +getBranchTaxonomy(branchId: string) TaxonomyTree
        -initializeStore() Promise~void~
    }

    class NavigationStore {
        -boolean isMarginaliaOpen
        -string currentNodeId
        -boolean isOmnibarOpen
        -string searchQuery
        +openMarginalia(nodeId: string) void
        +closeMarginalia() void
        +toggleOmnibar() void
        +setSearchQuery(q: string) void
    }

    class DynamicVarStore {
        -Record~string, number~ vars
        +setVar(name: string, value: number) void
        +getVar(name: string, fallback: number) number
        +reset() void
    }

    %% React Local State (Context API)
    class MathStoreContext {
        <<Context>>
        -Record~string, any~ variables
        -string[] currentSteps
        -Record~string, boolean~ highlights
        +setVariable(key: string, val: any) void
        +setHighlight(id: string, active: boolean) void
        +setStep(stepId: string) void
    }

    %% Logic Classes
    class StyleManager {
        -boolean isStep
        -boolean isHL
        -boolean anyH
        -ThemeColors theme
        +getOp(id: string, base: number) number
        +getW(id: string, base: number) number
        +getC(id: string, color: string) string
    }

    %% Interfaces and Data Models
    class ContentEntry {
        <<interface>>
        +string id
        +string slug
        +string contentType
        +string filePath
        +Record~string, any~ metadata
    }

    class Theorem {
        <<interface>>
        +string id
        +string title
        +string[] tags
        +string[] corollaries
        +string[] lemmas
        +string parentTheorem
        +ReactComponent Component
        +ReactComponent Simulation
    }

    class MathBoard {
        <<React Component>>
        +BoundingBox bounds
        +ThemeColors theme
        +mount(boardId: string) Board
        +unmount() void
    }

    %% Relaciones de Agregación y Composición
    ContentStore "1" *-- "*" ContentEntry : Contains
    ContentStore "1" o-- "*" Theorem : Hydrates
    
    %% Relaciones de Dependencia
    NavigationStore ..> ContentStore : Fetches Target Data
    
    %% Relaciones UI-Estado
    MathBoard "1" --> "1" MathStoreContext : Subscribes To
    MathBoard ..> StyleManager : Uses for Rendering Rules
    Theorem ..> MathBoard : Instantiates
