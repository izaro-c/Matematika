classDiagram
    %% Core State (Zustand Global)
    class ContentStore {
        +Map~string, Mathematician~ mathematicians
        +Map~string, Theorem~ theorems
        +Map~string, Lesson~ lessons
        +Map~string, Demo~ demos
        +Map~string, Definition~ definitions
        +Map~string, Example~ examples
        +Map~string, Exercise~ exercises
        +Map~string, Axiom~ axioms
        +Map~string, AxiomaticSystem~ axiomaticSystems
        +Map~string, Model~ models
        +getTheorem(id: string) Theorem
        +getLesson(id: string) Lesson
        +getDefinition(id: string) Definition
        +getDemo(id: string) Demo
        -init() void
    }

    class NavigationStore {
        -boolean isMarginaliaOpen
        -string currentNodeId
        -boolean isOmnibarOpen
        -string searchQuery
        +openMarginalia(nodeId: string) void
        +closeMarginalia() void
        +toggleOmnibar() void
        +setSearchQuery(q: string) void
    }

    class DynamicVarStore {
        -Record~string, number~ vars
        +setVar(name: string, value: number) void
        +getVar(name: string, fallback: number) number
        +reset() void
    }

    %% React Local State (Context API)
    class MathStoreContext {
        <<Context>>
        -Record~string, any~ variables
        -string[] currentSteps
        -Record~string, boolean~ highlights
        +setVariable(key: string, val: any) void
        +setHighlight(id: string, active: boolean) void
        +setStep(stepId: string) void
    }

    %% Logic Classes
    class StyleManager {
        -boolean isStep
        -boolean isHL
        -boolean anyH
        -ThemeColors theme
        +getOp(id: string, base: number) number
        +getW(id: string, base: number) number
        +getC(id: string, color: string) string
    }

    %% Interfaces and Data Models
    class BaseContent {
        <<interface>>
        +string id
        +string slug
        +string[] links
        +string[] seeAlso
        +MDXComponent Component
    }

    class ContentIndexEntry {
        <<interface>>
        +string id
        +string slug
        +string contentType
        +string filePath
        +Record~string, unknown~ metadata
    }

    class Theorem {
        <<interface>>
        +string title
        +string statement
        +string[] authors
        +string[] corollaries
        +string[] lemmas
        +string[] demos
        +MDXComponent Simulation
    }

    class Definition {
        <<interface>>
        +string title
        +string statement
        +MDXComponent Simulation
    }
    
    class Demo {
        <<interface>>
        +string title
        +string proofMethod
        +string layout
    }

    class MathBoard {
        <<React Component>>
        +BoundingBox bounds
        +ThemeColors theme
        +mount(boardId: string) Board
        +unmount() void
    }

    %% Herencia
    BaseContent <|-- Theorem
    BaseContent <|-- Definition
    BaseContent <|-- Demo

    %% Relaciones de Agregación y Composición
    ContentStore "1" *-- "*" ContentIndexEntry : Loads from JSON
    ContentStore "1" o-- "*" BaseContent : Hydrates (Aggregation)
    
    %% Relaciones de Dependencia
    NavigationStore ..> ContentStore : Fetches Target Data
    
    %% Relaciones UI-Estado
    MathBoard "1" --> "1" MathStoreContext : Subscribes To
    MathBoard ..> StyleManager : Uses for Rendering Rules
    Theorem ..> MathBoard : Instantiates
    Definition ..> MathBoard : Instantiates
