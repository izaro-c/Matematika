@startuml
skinparam classAttributeIconSize 0
skinparam classFontStyle normal
hide circle

class SistemaMatematika {
  + esploraBranche()
  + visualizzaDimostrazione()
  + aggiungiContenuto()
}

class Grafo {
  + ordinamentoTopologico
  + nodi
  + navigaConcetti()
  + valutaGrafoAttivo()
  + rimuoviContenuto()
  + ricalcolaOrdinamento()
  + aggiornaValidita()
  + verificaCicli()
}

abstract class Nodo {
  + identificativo
  + tipo
  + dipendenze
  + modificaContenuto()
}

class Teorema {
  + prove
}

class Assioma {
}

class Definizione {
}

class Prova {
  + identificativo
  + dipendenze
}

class Glossario {
  + termini
  + consultaGlossario()
}

class Modello {
  + identificativo
  + titolo
  + assiomi
  + esploraModelli()
}

class SistemaAssiomatico {
  + identificativo
  + titolo
  + assiomi
}

' Relazioni
SistemaMatematika "1" -- "1" Grafo : gestisce
SistemaMatematika "1" -- "1" Glossario : gestisce

Grafo "1" -- "1..*" Nodo : contiene
Nodo "1" -- "0..*" Nodo : dipende da

Teorema --|> Nodo
Assioma --|> Nodo
Definizione --|> Nodo

Teorema "1" -- "1..*" Prova : dimostrato da

Glossario "1" -- "0..*" Nodo : definisce

SistemaAssiomatico "1" -- "1..*" Assioma : composto da
Modello "1" -- "1..*" Assioma : soddisfa
Modello "0..*" -- "1" SistemaAssiomatico : istanzia
@enduml
