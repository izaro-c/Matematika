@startuml
actor "Autore" as A
participant ": SistemaMatematika" as Sys

A -> Sys : inserisciMetadati(nuovoNodo)
A -> Sys : definisciDipendenze(nodoId, dipendenze)
A -> Sys : salvaContenuto()
activate Sys
Sys -> Sys : verificaCicli()\n<<include UC13>>
alt grafo aciclico
  Sys -> Sys : persistiNuovoNodo()
  Sys --> A : confermaSalvataggio()
else ciclo rilevato
  Sys --> A : erroreValidazione("Dipendenze cicliche")
end
deactivate Sys
@enduml
