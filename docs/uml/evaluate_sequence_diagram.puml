@startuml
actor "Studente" as S
participant ": AxiomSandboxPanel" as B <<Boundary>>
participant ": GraphSandboxStore" as C <<Controller>>
participant ": Grafo" as E <<Entity>>
participant "nodo : Nodo" as N <<Entity>>

S -> B : modificaStatoAssioma(assiomaId)
B -> C : toggleAxiom(assiomaId)
activate C
C -> C : aggiorna activeAxioms
C -> E : evaluate(activeAxioms)
activate E
loop per ogni nodo in ordine topologico
  E -> N : isSatisfiedBy(validNodes)
  activate N
  return soddisfatto
end
return validNodes
deactivate E
C -> C : aggiorna validNodes
C --> B : stato aggiornato
deactivate C
B --> S : aggiornaInterfaccia(validNodes)
@enduml
