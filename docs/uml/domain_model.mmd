classDiagram
    class Grafo {
        +String id
        +Set~String~ nodiValidi
        +valuta()
    }
    class NodoBase {
        +String id
        +String titolo
    }
    class Teorema {
        +String asserto
        +List~String~ dimostrazioni
    }
    class Definizione {
        +String termine
        +String corpo
    }
    class Assioma {
        +Boolean attivo
    }
    class Dipendenza {
        +String sorgente
        +String destinazione
    }

    Grafo "1" *-- "*" NodoBase : contiene
    NodoBase <|-- Teorema
    NodoBase <|-- Definizione
    NodoBase <|-- Assioma
    Teorema "1" --> "*" Dipendenza : ha
    Dipendenza "*" --> "1" NodoBase : verso
