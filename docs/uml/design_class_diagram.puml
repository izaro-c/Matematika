@startuml
skinparam classAttributeIconSize 0

package "Boundary" {
  class AxiomSandboxPanel <<React>> {
    + renderPanel()
    + onToggleAxiom(assiomaId)
  }

  class SearchOmnibar <<React>> {
    + onSearch(query)
  }
}

package "Controller" {
  class GraphSandboxStore <<Zustand Store>> {
    + activeAxioms : Record
    + validNodes : Set
    + toggleAxiom(assiomaId)
    + clearSandbox()
  }

  class GraphStore <<Zustand Store>> {
    + activeModels : List
    + baseNodes : List
    + toggleModel(modelId)
  }

  class "graph.worker.ts" as GraphWorker <<Web Worker>> {
    + computeGraph()
  }
}

package "Entity" {
  class Grafo {
    + from(structure)
    + evaluate(activeAxioms)
    + isDagValid()
    + computeDisabledAxiomsFromModels(models, ids, axioms)
  }

  class Nodo {
    + id
    + type
    + isAxiom()
    + isTheorem()
    + isSatisfiedBy(validNodes)
  }
}

package "Database" {
  class ContentStore <<Singleton>> {
    + getInstance()
    + getTheorem(id)
    + getAllModels()
    + getAllAxioms()
  }

  class "graph_structure.json" as GraphJSON <<JSON>>
  class "contentIndex.json" as IndexJSON <<JSON>>
}

AxiomSandboxPanel --> GraphSandboxStore : toggleAxiom()
AxiomSandboxPanel --> ContentStore : carica assiomi

SearchOmnibar --> ContentStore : cerca contenuti

GraphSandboxStore --> Grafo : evaluate()
GraphSandboxStore --> GraphJSON : carica struttura

GraphStore --> GraphWorker : computeGraph()
GraphStore --> ContentStore : carica modelli

Grafo --> Nodo : valuta

ContentStore --> IndexJSON : legge indice
ContentStore --> GraphJSON : legge struttura
@enduml
