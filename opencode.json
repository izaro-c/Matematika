{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "share": "manual",
  "instructions": [
    "AGENTS.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
