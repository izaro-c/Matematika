{
  "name": "matematika",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://izaro-c.github.io/Matematika/",
  "scripts": {
    "dev": "npm run lean:graph && npm run generate-index && npm run content:coverage && npm run validate-graph && npm run validate-references && vite",
    "prebuild": "npm run lean:graph && npm run generate-index && npm run content:coverage && npm run validate-graph && npm run validate-references",
    "generate-index": "tsx scripts/core/generate-content-index.ts",
    "diagram-usages:index": "tsx scripts/editor/generate-diagram-usages.ts",
    "diagram-usages:check": "tsx scripts/editor/generate-diagram-usages.ts --check",
    "content:coverage": "tsx scripts/core/generate-content-coverage.ts",
    "ai:index": "tsx scripts/ai/generate-ai-indexes.ts",
    "ai:review": "tsx scripts/ai/review-working-tree.ts",
    "ai:debt": "tsx scripts/ai/generate-debt-report.ts",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "docs:generate": "node scripts/core/generate_schema_docs.cjs",
    "docs:build": "typedoc",
    "docs:pdf": "cd docs/documento_progetto && pdflatex documento_progetto.tex && rm -f *.aux *.log *.out *.toc",
    "docs:uml": "java -jar scripts/plantuml.jar docs/uml/lean_architecture.puml docs/uml/lean_pipeline_sequence.puml docs/uml/proof_trace_factor_bruijn.puml docs/uml/project_class_diagram.puml -o images",
    "validate-graph": "tsx scripts/core/validate-logical-graph.ts",
    "validate-references": "tsx scripts/core/validate-cross-references.ts",
    "lean:build": "cd lean && lake build",
    "lean:graph": "tsx scripts/core/generate-lean-graph.ts",
    "validate-lean": "npm run validate-graph && npm run lean:build && npm run lean:graph && npm run validate-no-fake-lean-certificates && tsx scripts/core/validate-lean-diff.ts",
    "validate-no-fake-lean-certificates": "tsx scripts/core/validate-no-fake-lean-certificates.ts",
    "bridge:audit": "tsx scripts/core/validate-bridge-phase.ts",
    "validate-no-mathlib": "tsx scripts/core/validate-no-mathlib.ts",
    "bridge:closed": "tsx scripts/core/validate-bridge-phase.ts --closed",
    "full-check": "npm run lint && npm run typecheck && npm run test && npm run depcruise && npm run validate-references && npm run validate-graph && npm run validate-lean && npm run content:coverage && npm run bridge:audit",
    "test": "vitest run",
    "test:report": "tsx tests/scripts/generate-test-report.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx tests/e2e/editor/editor-safe-ux.e2e.ts",
    "test:e2e:editor": "tsx tests/e2e/editor/editor-safe-ux.e2e.ts",
    "test:e2e:ui": "tsx tests/e2e/editor/editor-safe-ux.e2e.ts",
    "editor:roundtrip:audit": "tsx scripts/editor/audit-mdx-roundtrip.ts --audit",
    "editor:roundtrip:check": "tsx scripts/editor/audit-mdx-roundtrip.ts --check",
    "editor:roundtrip:strict": "tsx scripts/editor/audit-mdx-roundtrip.ts --strict",
    "test:editor": "vitest run tests/features/editor",
    "editor:test:unit": "vitest run tests/features/editor/document tests/features/editor/diagrams tests/features/editor/state tests/features/editor/parser.test.ts tests/features/editor/validation.test.ts tests/features/editor/editorContracts.test.ts tests/features/editor/fixtures.test.ts",
    "editor:test:integration": "vitest run tests/features/editor/persistence tests/features/editor/useEditorCore.test.ts tests/features/editor/roundtrip.test.ts",
    "editor:test:e2e": "tsx scripts/editor/check-editor-e2e-suite.ts && tsx tests/e2e/editor/editor-safe-ux.e2e.ts",
    "editor:test:coverage": "vitest run tests/features/editor --test-timeout=180000 --coverage --coverage.include='src/features/editor/**' --coverage.reporter=text --coverage.reporter=json-summary && tsx scripts/editor/check-editor-coverage.ts",
    "editor:lint": "eslint src/features/editor tests/features/editor scripts/editor vite.config.ts --max-warnings=119",
    "editor:architecture": "npm run depcruise && npm run editor:safety:check",
    "editor:safety:check": "tsx scripts/editor/check-editor-safety.ts",
    "editor:generated:check": "tsx scripts/editor/check-generated-artifacts.ts",
    "editor:full-check": "npm run editor:generated:check && npm run editor:roundtrip:check && npm run editor:lint && npm run editor:test:unit && npm run editor:test:integration && npm run editor:architecture && npm run typecheck && npm run build",
    "editor:release-check": "npm run editor:full-check && npm run editor:test:coverage && npm run editor:test:e2e && npm run validate-references && npm run validate-graph && npm run validate-lean && npm run bridge:audit",
    "editor:lossless:audit": "tsx scripts/editor/audit-lossless-compatibility.ts --audit",
    "editor:lossless:check": "tsx scripts/editor/audit-lossless-compatibility.ts --check",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "depcruise": "depcruise src",
    "depcruise:graph": "depcruise src --output-type dot | dot -T svg > docs/uml/dependency_graph.svg",
    "depcruise:report": "depcruise src --output-type err-html > docs/dependency_report.html",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^9.109.5",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "fuse.js": "^7.4.2",
    "ghpages": "^0.0.10",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "wouter": "^3.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "puppeteer": "^24.43.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
