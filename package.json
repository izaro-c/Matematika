{
  "name": "matematika",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://izaro-c.github.io/Matematika/",
  "scripts": {
    "dev": "npm run generate-index && npm run validate-graph && npm run validate-references && vite",
    "prebuild": "npm run generate-index && npm run validate-graph && npm run validate-references",
    "generate-index": "tsx scripts/core/generate-content-index.ts",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "lint": "eslint .",
    "preview": "vite preview",
    "docs:generate": "node scripts/core/generate_schema_docs.cjs",
    "docs:build": "typedoc",
    "docs:pdf": "cd docs/documento_progetto && pdflatex documento_progetto.tex && rm -f *.aux *.log *.out *.toc",
    "docs:uml": "java -jar scripts/plantuml.jar docs/uml/use_cases.puml docs/uml/domain_model.puml docs/uml/domain_model_refined.puml docs/uml/ssd_valuta_grafo.puml docs/uml/ssd_aggiungi_contenuto.puml docs/uml/design_class_diagram.puml -o ../documento_progetto/images",
    "validate-graph": "tsx scripts/core/validate-logical-graph.ts",
    "validate-references": "tsx scripts/core/validate-cross-references.ts",
    "test": "vitest run",
    "test:report": "tsx tests/scripts/generate-test-report.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "depcruise": "depcruise src",
    "depcruise:graph": "depcruise src --output-type dot | dot -T svg > docs/uml/dependency_graph.svg",
    "depcruise:report": "depcruise src --output-type err-html > docs/dependency_report.html",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^9.109.5",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "fuse.js": "^7.4.2",
    "ghpages": "^0.0.10",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "puppeteer": "^24.43.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "wouter": "^3.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs}": []
  }
}
